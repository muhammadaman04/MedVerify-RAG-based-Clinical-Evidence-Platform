# MedVerify Backend — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-very-long-random-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8

# App
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Resend (invite emails) — get your key at https://resend.com
# Leave empty for dev mode (invite links print to console instead)
RESEND_API_KEY=
# IMPORTANT: onboarding@resend.dev only sends to your own Resend account email.
# To send to any recipient, verify a domain at resend.com and use: noreply@yourdomain.com
RESEND_FROM_EMAIL=onboarding@resend.dev
