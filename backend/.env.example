# MedVerify Backend — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=your-very-long-random-secret-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8

# App
APP_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email — Gmail SMTP (uses Python's built-in smtplib, no extra package needed)
# Leave SMTP_USER empty to use dev mode (invite links print to the backend console instead)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=MedVerify

# Pinecone (Phase 2 — vector store)
# Get your API key at https://pinecone.io
# The index will be auto-created by the app (384-dim, cosine metric)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=medverify

# Supabase Storage (Phase 2 — file storage)
# Uses the same credentials above. The 'documents' bucket is auto-created.
SUPABASE_STORAGE_BUCKET=documents

# Groq LLM (Phase 3 — answer generation & evidence verification)
# Get your free API key at https://console.groq.com
GROQ_API_KEY=
